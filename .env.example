# Tin control plane that actually runs the scan (keyless public endpoint).
TIN_API_BASE=https://api.tin.computer

# Rate limiting (optional but recommended in production). Without these the limiter
# is a no-op and the server still runs. Create a free Upstash Redis and paste here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_PER_IP=5
RATE_LIMIT_PER_IP_WINDOW=10 m
RATE_LIMIT_GLOBAL=200
RATE_LIMIT_GLOBAL_WINDOW=1 h

# Funnel analytics (optional). Without a key, tracking is a no-op.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
